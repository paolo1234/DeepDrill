; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be manually edited with care.

config_version=5

[application]

config/name="Deep Drill"
config/version="0.2"
config/features=PackedStringArray("4.6")
run/main_scene="res://scenes/main_menu.tscn"

[autoload]

McpInteractionServer="*res://mcp_interaction_server.gd"

























GameState="*res://scripts/gamestate.gd"
SaveManager="*res://scripts/save_manager.gd"
AdManager="*res://scripts/ad_manager.gd"
Effects="*res://scripts/effects.gd"

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/stretch/mode="canvas_items"
window/stretch/aspect="keep_width"

[input]

; Using built-in ui_left and ui_right instead of custom inputs to avoid parsing errors

[rendering]

renderer/rendering_method="gl_compatibility"
environment/defaults/default_clear_color=Color(0.102, 0.102, 0.18, 1)
